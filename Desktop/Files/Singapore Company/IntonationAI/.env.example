# Firebase / GCP (production project: intonationai)
FIREBASE_PROJECT_ID=intonationai
FIREBASE_WEB_API_KEY=
GOOGLE_CLOUD_PROJECT=intonationai
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Vertex AI
VERTEX_AI_MODEL=claude-sonnet-4-6-20250514
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Cloud Storage
GCS_BUCKET=

# Database (Cloud SQL or local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intonation_ai

# Stripe (Free + Pro only; map webhooks to plan=pro for PRO price IDs)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
# Optional default trial on checkout when client omits trial_days (omit trial_days in API to use this)
STRIPE_TRIAL_DAYS=

# Frontend pricing display (must match Stripe Price amounts; build-time env for Next.js)
# NEXT_PUBLIC_PRICING_PRO_MONTHLY_USD=14.99
# NEXT_PUBLIC_PRICING_PRO_ANNUAL_PER_MONTH_USD=9.99
# NEXT_PUBLIC_PRICING_ANNUAL_SAVE_PERCENT=33
# NEXT_PUBLIC_TRIAL_DAYS=7

# App
# development | production (production requires FIREBASE_PROJECT_ID)
ENVIRONMENT=development
# Local only: set false to rely on Alembic migrations instead of SQLAlchemy create_all
DATABASE_AUTO_CREATE=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Frontend canonical URL for SEO (Open Graph, sitemap, hreflang). Use your Firebase or custom domain in production.
# NEXT_PUBLIC_SITE_URL=https://intonationai.web.app

# Firebase App Check (web client — required for Firestore reads with current rules)
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=
# Optional Cloud Run: require App Check on selected API routes + coach WebSocket
# FIREBASE_APP_CHECK_ENFORCE=false

# Observability (optional)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# ENABLE_CLOUD_TRACE=false
# LOG_JSON=false
# APP_RELEASE= (set the same value as NEXT_PUBLIC_APP_RELEASE on the frontend build when possible)
# NEXT_PUBLIC_APP_RELEASE=
# Browser Sentry: optional deploy label (falls back to NEXT_PUBLIC_VERCEL_ENV then NODE_ENV)
# NEXT_PUBLIC_APP_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# COACH_PROMPT_VERSION=1 — match NEXT_PUBLIC_COACH_PROMPT_VERSION in frontend build when rolling prompts
# NEXT_PUBLIC_COACH_PROMPT_VERSION=1
# Max messages (user+coach lines) sent to Gemini per turn; full log remains in Firestore
# COACH_LLM_HISTORY_MESSAGES=30

# Resilience (timeouts, seconds)
# COACH_LLM_TIMEOUT_SEC=120
# GCS_OPERATION_TIMEOUT_SEC=60
# STRIPE_HTTP_TIMEOUT_SEC=30
# GEMINI_CIRCUIT_FAILURE_THRESHOLD=5
# GEMINI_CIRCUIT_OPEN_SEC=60
# READINESS_DB_TIMEOUT_SEC=5
# READINESS_GCS_TIMEOUT_SEC=12
