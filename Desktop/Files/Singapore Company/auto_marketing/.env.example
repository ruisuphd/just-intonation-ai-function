# GCP
GCP_PROJECT_ID=intonation-labs-marketing
GCP_REGION=asia-southeast1
FIRESTORE_DATABASE=(default)

# Cloud Storage bucket
BRAND_DOCS_BUCKET=brand-documents-intonation-labs-marketing
APP_URL=
ALLOWED_ORIGINS=http://localhost:3000

# Vertex AI — Gemini
GEMINI_REGION=global

# Vertex AI — Embeddings
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=2048

# Logging
LOG_LEVEL=INFO

# Redis (optional — enables persistent rate limiting and caching)
# REDIS_URL=redis://localhost:6379

# Sentry (optional — set SENTRY_DSN for backend, NEXT_PUBLIC_SENTRY_DSN for frontend)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# SMTP daily digest
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Stripe
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# App entitlements
INTERNAL_TEST_EMAILS=yoryouyoi@gmail.com
