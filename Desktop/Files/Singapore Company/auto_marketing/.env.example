# GCP
GCP_PROJECT_ID=intonation-labs-marketing
GCP_REGION=asia-southeast1
# Latency: Firebase App Hosting may be in asia-east1 while Cloud Run API uses GCP_REGION.
# Cross-region adds RTT on every browser→API call; colocate when your host supports it.
FIRESTORE_DATABASE=(default)

# Cloud Storage bucket
BRAND_DOCS_BUCKET=brand-documents-intonation-labs-marketing
APP_URL=
# Browser → FastAPI origin. Required for `next build` / production; local dev defaults to http://localhost:8080 when unset.
# Example: https://your-api-xxxxx-as.a.run.app (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080
# Must include browser origin (e.g. App Hosting URL) for credentialed API calls.
ALLOWED_ORIGINS=http://localhost:3000

# Vertex AI — Gemini
GEMINI_REGION=global
# Set to 1 to retry marketing_chat / quick_generate on a stable fallback model after primary failures
# GEMINI_ENABLE_MODEL_FALLBACK=1

# Vertex AI — Embeddings
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=2048

# Logging
LOG_LEVEL=INFO

# API: include exception detail in JSON 500 responses (local debugging only; never in production)
# DEBUG_API_ERRORS=1

# Optional closed beta: comma-separated normalized emails. When set, only these accounts can call the API.
# BETA_ALLOWED_EMAILS=founder@company.com,cofounder@company.com

# OAuth (required on Cloud Run / managed runtimes for LinkedIn/X — set Secret Manager secret oauth-state-secret or this env)
# OAUTH_STATE_SECRET=

# Redis (optional — enables persistent rate limiting and caching)
# REDIS_URL=redis://localhost:6379

# Sentry (optional — set SENTRY_DSN for backend, NEXT_PUBLIC_SENTRY_DSN for frontend)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# SMTP daily digest — platform fallback when a tenant has no per-tenant SMTP doc
# (Per-tenant SMTP is stored at tenants/{tenantId}/tenant_settings/smtp via PUT /api/admin/smtp-config)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Stripe
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Frontend: embedded Pricing Table (Settings → Billing). Use test keys/table in dev; live only in prod.
# Stripe webhooks: POST https://<API_HOST>/webhooks/stripe (or /billing/webhook — same handler).
# Pricing table success/cancel: {APP_URL}/billing?checkout=success | canceled
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=
