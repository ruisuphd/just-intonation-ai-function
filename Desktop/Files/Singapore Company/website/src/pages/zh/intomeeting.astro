---
import Base from '@/layouts/Base.astro';
import { t, localePath } from '@/i18n/index';
import Breadcrumb from '@/components/Breadcrumb.astro';

const lang = 'zh';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'IntoMeeting',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: t(lang, 'page.intomeeting.desc'),
  url: 'https://intomeeting.app',
  creator: {
    '@type': 'Organization',
    name: 'Intonation Labs Pte. Ltd.',
    url: 'https://www.intonationlabs.com',
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/OnlineOnly',
  },
};

const panels = [
  { label: '转录', icon: 'M9 12h6m-3-3v6m-7 3h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v13l4-4z' },
  { label: 'AI建议', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636-.707.707M21 12h-1M4 12H3m3.343-5.657-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  { label: '笔记', icon: 'M11 5H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2v-5m-1.414-9.414a2 2 0 1 1 2.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
];
---

<Base
  title={t(lang, 'page.intomeeting.title')}
  description={t(lang, 'page.intomeeting.desc')}
  lang={lang}
  jsonLd={jsonLd}
  canonicalPath="/intomeeting/"
>
  <Breadcrumb lang={lang} items={[
    { label: t(lang, 'breadcrumb.home'), href: localePath(lang, '/') },
    { label: 'IntoMeeting' },
  ]} />

  <section class="section" aria-labelledby="product-title">
    <div class="container">
      <div class="section__header reveal">
        <p class="section__label">{t(lang, 'meet.label')}</p>
        <h1 id="product-title" class="section__title">{t(lang, 'meet.title')}</h1>
        <p class="section__subtitle">{t(lang, 'meet.subtitle')}</p>
      </div>

      <div class="product__inner">
        <div class="reveal">
          <div class="product__features">
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'meet.f1.title')}</p>
                <p class="product__feature-desc">{t(lang, 'meet.f1.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'meet.f2.title')}</p>
                <p class="product__feature-desc">{t(lang, 'meet.f2.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'meet.f3.title')}</p>
                <p class="product__feature-desc">{t(lang, 'meet.f3.desc')}</p>
              </div>
            </div>
            <div class="product__feature">
              <div class="product__feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              </div>
              <div>
                <p class="product__feature-title">{t(lang, 'meet.f4.title')}</p>
                <p class="product__feature-desc">{t(lang, 'meet.f4.desc')}</p>
              </div>
            </div>
          </div>

          <p class="product__coming mt-xl">{t(lang, 'meet.coming')}</p>
          <p class="product__stack">{t(lang, 'meet.stack')}</p>

          <div class="mt-xl product__cta-row">
            <a href="https://intomeeting.app" target="_blank" rel="noopener noreferrer" class="btn btn--primary">{t(lang, 'meet.cta')}</a>
            <a href={localePath(lang, '/contact/')} class="btn btn--outline">{t(lang, 'meet.partner.cta')} <span class="arrow" aria-hidden="true">&rarr;</span></a>
          </div>
        </div>

        <div class="product__visual reveal reveal-delay-2" aria-hidden="true">
          <div class="meet__screen">
            <div class="product__screen-bar"><span></span><span></span><span></span></div>
            <div class="meet__panels">
              {panels.map((panel) => (
                <div class="meet__panel">
                  <div class="meet__panel-header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                      <path d={panel.icon} />
                    </svg>
                    <span>{panel.label}</span>
                  </div>
                  <div class="meet__panel-lines">
                    <span></span><span></span><span style="width:60%"></span>
                  </div>
                </div>
              ))}
            </div>
            <div class="product__screen-label">{t(lang, 'meet.screen')}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-labelledby="partnership-title">
    <div class="container text-center">
      <div class="reveal">
        <h2 id="partnership-title" class="section__title">{t(lang, 'meet.partner')}</h2>
        <div class="mt-lg">
          <a href={localePath(lang, '/contact/')} class="btn btn--outline">{t(lang, 'meet.partner.cta')} <span class="arrow" aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section" aria-labelledby="cta-title">
    <div class="container text-center">
      <h2 id="cta-title" class="section__title reveal">{t(lang, 'cta.title')}</h2>
      <p class="section__subtitle mx-auto reveal reveal-delay-1">{t(lang, 'cta.subtitle')}</p>
      <div class="cta__actions reveal reveal-delay-2">
        <a href="https://calendar.app.google/JDEqiw8AM2UbtU6X6" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg">{t(lang, 'cta.btn1')}</a>
        <a href={localePath(lang, '/contact/')} class="btn btn--outline-light btn--lg">{t(lang, 'cta.btn2')}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .product__coming {
    font-family: var(--f-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-accent);
  }
  .product__stack {
    font-size: 0.8125rem;
    color: var(--c-text-tertiary);
    margin-top: var(--s-sm);
  }
  .product__cta-row {
    display: flex;
    gap: var(--s-md);
    flex-wrap: wrap;
    align-items: center;
  }
  .meet__screen {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }
  .meet__panels {
    display: flex;
    gap: 1px;
    background: var(--c-border);
    padding: var(--s-md);
    gap: var(--s-sm);
  }
  .meet__panel {
    flex: 1;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 6px;
    padding: var(--s-sm);
    min-width: 0;
  }
  .meet__panel-header {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--c-text-secondary);
    margin-bottom: var(--s-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .meet__panel-lines {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .meet__panel-lines span {
    display: block;
    height: 6px;
    background: var(--c-border);
    border-radius: 3px;
    width: 100%;
  }
</style>
